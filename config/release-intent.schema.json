{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-praetor.local/schema/release-intent/v1",
  "title": "Codex Praetor release intent",
  "type": "object",
  "required": ["schema", "product", "version", "previous_version", "tag", "release_required", "release_mode", "artifact"],
  "properties": {
    "schema": { "const": "codex-praetor-release-intent/v1" },
    "product": { "const": "codex-praetor" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$" },
    "previous_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$" },
    "tag": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$" },
    "release_required": { "const": true },
    "release_mode": { "const": "auto_on_main" },
    "artifact": { "type": "string", "minLength": 1 },
    "reason": { "type": "string" }
  }
}
