{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-praetor.local/schema/evaluation-suite/v1",
  "title": "Codex Praetor real task evaluation suite",
  "type": "object",
  "required": ["schema", "suite_id", "tasks"],
  "properties": {
    "schema": { "const": "codex-praetor-evaluation-suite/v1" },
    "suite_id": { "type": "string", "minLength": 1 },
    "tasks": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/task" } }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["task_id", "task_family", "goal", "mode", "task_kind", "provider_candidates", "allowed_paths", "forbidden_paths", "acceptance", "required_checks", "budget", "failure_injection"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "task_family": { "enum": ["read_only_diagnosis", "bounded_code_change", "fixed_test_execution", "failure_recovery"] },
        "goal": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["readonly", "edit"] },
        "task_kind": { "enum": ["local_audit", "test_execution", "code_change"] },
        "provider_candidates": { "type": "array", "minItems": 1, "items": { "enum": ["qoder", "codebuddy"] } },
        "allowed_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "forbidden_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "acceptance": { "type": "string", "minLength": 1 },
        "required_checks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "budget": { "type": "object", "required": ["max_turns", "max_wall_seconds"], "properties": { "max_turns": { "type": "integer", "minimum": 1 }, "max_wall_seconds": { "type": "integer", "minimum": 60 } } },
        "failure_injection": { "type": "string", "minLength": 1 },
        "sensitivity": { "enum": ["public_code_only", "no_auth_material"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
