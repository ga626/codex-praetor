{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "product", "capabilities"],
  "properties": {
    "schema": { "const": "codex-praetor-public-capabilities/v1" },
    "product": { "const": "codex-praetor" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "audience", "entry", "package_requirements", "scenario", "risk_tier"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "audience": { "enum": ["installed_plugin", "release_bundle", "developer_only"] },
          "entry": { "type": "object" },
          "package_requirements": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "scenario": { "type": "string", "minLength": 1 },
          "risk_tier": { "enum": ["deterministic_artifact", "external_provider"] }
        }
      }
    }
  }
}
