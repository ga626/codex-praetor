    "dependencies":  {
                         "@modelcontextprotocol/sdk":  "^1.29.0",
                         "zod":  "^4.4.3"
                     },
    "devDependencies":  {
                            "@types/node":  "^25.0.0",
                            "esbuild":  "^0.28.1",
                            "typescript":  "^5.9.3"
                        }
}
