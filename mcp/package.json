{
    "name":  "codex-praetor-mcp",
    "version":  "0.6.1-alpha",
    "description":  "Thin MCP wrapper for Codex Praetor dry-run dispatch and job state.",
    "type":  "module",
    "main":  "dist/server.js",
    "bin":  {
                "codex-praetor-mcp":  "dist/server.js"
            },
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "build:plugin":  "node scripts/package-plugin-mcp.js",
                    "start":  "node dist/server.js",
                    "test":  "tsc -p tsconfig.json \u0026\u0026 npm run build:plugin \u0026\u0026 node dist/self-test.js"
                },
    "keywords":  [
                     "codex",
                     "mcp",
                     "worker",
                     "orchestration"
                 ],
